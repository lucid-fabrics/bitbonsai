// BitBonsai Prisma Schema
// Complete database schema for media optimization platform
//
// DEFAULT DATABASE: SQLite (file-based, zero-configuration)
// - Perfect for single-node deployments
// - No external database server required
// - Production-ready for most use cases
//
// COMMERCIAL EDITION: PostgreSQL support available
// - Required for multi-node deployments
// - Enhanced performance and scalability
// - Simply change provider to "postgresql" and update DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  USER
}

enum LicenseTier {
  FREE
  PATREON
  COMMERCIAL_STARTER
  COMMERCIAL_PRO
  COMMERCIAL_ENTERPRISE
}

enum LicenseStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum NodeRole {
  MAIN
  LINKED
}

enum NodeStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum SyncStatus {
  PENDING
  SYNCING
  COMPLETED
  FAILED
}

enum AccelerationType {
  CPU
  INTEL_QSV
  NVIDIA
  AMD
  APPLE_M
}

enum MediaType {
  MOVIE
  TV_SHOW
  ANIME
  ANIME_MOVIE
  MIXED
  OTHER
}

enum PolicyPreset {
  BALANCED_HEVC
  FAST_HEVC
  QUALITY_AV1
  COPY_IF_COMPLIANT
  CUSTOM
}

enum TargetCodec {
  HEVC
  AV1
  VP9
  H264
}

enum JobStage {
  DETECTED
  HEALTH_CHECK
  NEEDS_DECISION // User decision required before proceeding (e.g., AC3 audio + MP4)
  QUEUED
  ENCODING
  PAUSED
  PAUSED_LOAD // CRITICAL FIX: Auto-paused due to high system load
  VERIFYING
  COMPLETED
  FAILED
  CANCELLED
}

enum FileHealthStatus {
  UNKNOWN
  HEALTHY
  WARNING
  AT_RISK
  CORRUPTED
}

enum JobEventType {
  FAILED             // Job failed during encoding
  CANCELLED          // User cancelled the job
  RESTARTED          // Job restarted after failure
  AUTO_HEALED        // Job auto-healed after backend restart
  BACKEND_RESTART    // Job interrupted by backend restart
  TIMEOUT            // Job timed out
}

// ============================================================================
// SETTINGS MODEL (System Configuration)
// ============================================================================

model Settings {
  id                           String   @id @default(cuid())
  isSetupComplete              Boolean  @default(false)
  allowLocalNetworkWithoutAuth Boolean  @default(false)
  defaultQueueView             String   @default("ENCODING") // Default queue filter view (ENCODING, QUEUED, COMPLETED, FAILED, ALL, etc.)
  readyFilesCacheTtlMinutes    Int      @default(5) // Cache TTL for /api/v1/libraries/ready endpoint (min: 5 minutes)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@map("settings")
}

// ============================================================================
// USER MODEL (Authentication & Authorization)
// ============================================================================

model User {
  id           String    @id @default(cuid())
  username     String    @unique
  email        String    @unique
  passwordHash String // bcrypt hashed password
  role         UserRole  @default(USER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  // Refresh token for JWT token rotation
  refreshToken          String?
  refreshTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@index([isActive])
  @@map("users")
}

// ============================================================================
// LICENSE MODEL
// ============================================================================

model License {
  id                   String        @id @default(cuid())
  key                  String        @unique
  tier                 LicenseTier
  status               LicenseStatus
  email                String
  maxNodes             Int
  maxConcurrentJobs    Int
  features             Json // Feature flags: { multiNode: true, advancedPresets: true, api: true }
  validUntil           DateTime? // Null = perpetual/lifetime
  stripeCustomerId     String?
  stripeSubscriptionId String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relations
  nodes   Node[]
  metrics Metric[]

  @@index([status])
  @@index([tier])
  @@index([email])
  @@index([validUntil])
  @@map("licenses")
}

// ============================================================================
// NODE MODEL
// ============================================================================

model Node {
  id               String           @id @default(cuid())
  name             String
  role             NodeRole
  status           NodeStatus
  version          String
  acceleration     AccelerationType
  pairingToken     String?          @unique // Used during pairing process, null after paired
  pairingExpiresAt DateTime? // Pairing token expiration (10 minutes)
  apiKey           String           @unique // For node authentication
  lastHeartbeat    DateTime
  uptimeSeconds    Int              @default(0)
  maxWorkers       Int              @default(1) // Number of concurrent encoding jobs
  cpuLimit         Int              @default(80) // Maximum CPU usage percentage (1-100)

  // Policy Sync Fields (Child Node Configuration)
  lastSyncedAt   DateTime?   // When policies/settings were last synced to this child node
  syncStatus     SyncStatus  @default(PENDING) // Current sync status (PENDING, SYNCING, COMPLETED, FAILED)
  syncRetryCount Int         @default(0) // Number of sync retry attempts (max 3)
  syncError      String?     // Error message if sync failed

  // Relations
  licenseId String
  license   License @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  libraries Library[]
  jobs      Job[]
  metrics   Metric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([role])
  @@index([licenseId])
  @@index([lastHeartbeat])
  @@index([syncStatus])
  @@map("nodes")
}

// ============================================================================
// LIBRARY MODEL
// ============================================================================

model Library {
  id             String    @id @default(cuid())
  name           String
  path           String // Absolute path to library folder
  mediaType      MediaType
  enabled        Boolean   @default(true)
  watchEnabled   Boolean   @default(false) // Enable automatic file watching (inotify)
  lastScanAt     DateTime?
  totalFiles     Int       @default(0)
  totalSizeBytes BigInt    @default(0)

  // Relations
  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  // Default encoding policy for this library
  defaultPolicyId String?
  defaultPolicy   Policy? @relation("LibraryDefaultPolicy", fields: [defaultPolicyId], references: [id], onDelete: SetNull)

  policies Policy[] @relation("LibraryPolicies")
  jobs     Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nodeId, path]) // Prevent duplicate paths on same node
  @@index([nodeId])
  @@index([enabled])
  @@index([mediaType])
  @@index([lastScanAt])
  @@index([watchEnabled])
  @@index([defaultPolicyId])
  @@map("libraries")
}

// ============================================================================
// POLICY MODEL
// ============================================================================

model Policy {
  id               String       @id @default(cuid())
  name             String
  preset           PolicyPreset
  targetCodec      TargetCodec
  targetQuality    Int // CRF value (0-51, lower = better quality)
  deviceProfiles   Json // { appleTv: bool, roku: bool, web: bool, chromecast: bool }
  advancedSettings Json // { ffmpegFlags: string[], hwaccel: string, etc }
  atomicReplace    Boolean      @default(true) // Replace original atomically (rename)
  verifyOutput     Boolean      @default(true) // Verify output playability
  skipSeeding      Boolean      @default(true) // Skip files currently seeding in torrent clients

  // Relations
  libraryId String?
  library   Library? @relation("LibraryPolicies", fields: [libraryId], references: [id], onDelete: SetNull)

  // Reverse relation for default policy
  defaultForLibraries Library[] @relation("LibraryDefaultPolicy")

  jobs Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([libraryId])
  @@index([preset])
  @@index([targetCodec])
  @@map("policies")
}

// ============================================================================
// JOB MODEL
// ============================================================================

model Job {
  id              String    @id @default(cuid())
  filePath        String // Full path to file
  fileLabel       String // User-friendly name (e.g., "Movie Name (2024).mkv")
  sourceCodec     String // Original codec (H.264, HEVC, etc)
  targetCodec     String // Target codec
  stage           JobStage
  progress        Float     @default(0) // 0.0 to 100.0
  etaSeconds      Int? // Estimated time to completion
  fps             Float? // Current encoding speed (frames per second)
  beforeSizeBytes BigInt // Original file size
  afterSizeBytes  BigInt? // Encoded file size (null until completed)
  savedBytes      BigInt? // Bytes saved (can be negative if larger)
  savedPercent    Float? // Percentage saved
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime? // When job failed (for FAILED status)
  error           String? // Error message if failed
  isBlacklisted   Boolean           @default(false) // User marked this file to never encode automatically
  retryCount      Int               @default(0) // Number of encoding retry attempts (max 3)
  nextRetryAt     DateTime? // When to retry next (for exponential backoff)

  // Auto-Heal Fields (TRUE RESUME tracking)
  autoHealedAt       DateTime? // When this job was automatically healed by system restart
  autoHealedProgress Float?    // Progress percentage when auto-healed (for visual indicator on progress bar)

  // Health Check Fields
  healthStatus         FileHealthStatus @default(UNKNOWN) // File health status
  healthScore          Int              @default(0) // Health score 0-100
  healthMessage        String? // Detailed health message or warning
  healthCheckedAt      DateTime? // When health check was performed
  healthCheckStartedAt DateTime? // HIGH PRIORITY FIX: When health check started (prevents orphan detection)
  healthCheckRetries   Int              @default(0) // Number of health check retry attempts

  // Health Check Decision Fields (NEEDS_DECISION state)
  decisionRequired Boolean @default(false) // Does this job require user decision before proceeding?
  decisionIssues   String? // JSON array of HealthCheckIssue objects requiring decisions
  decisionMadeAt   DateTime? // When user resolved the decision
  decisionData     String? // JSON object with user's decision choices

  // Priority Fields
  priority      Int       @default(0) // 0=normal, 1=high, 2=top (max 3 top priority at once)
  prioritySetAt DateTime? // When priority was last changed (for tracking)

  // Resume State Fields (TRUE RESUME after backend crash/restart)
  tempFilePath       String?   // Path to partial encoded file (e.g., "/path/video.mp4.tmp.mp4")
  resumeTimestamp    String?   // HH:MM:SS.MS where encoding stopped
  lastProgressUpdate DateTime? // When progress was last saved to DB

  // Encoding Preview Fields (Live thumbnails during encoding)
  previewImagePaths String? // JSON array of preview image paths (generated from temp file)

  // Original File Tracking (Keep Original Feature)
  keepOriginalRequested Boolean @default(false) // User clicked "Keep Original" during encoding
  originalBackupPath    String? // Path to .original backup if kept (e.g., "/path/movie.mkv.original")
  originalSizeBytes     BigInt? // Size of original file before encoding
  replacementAction     String? // 'REPLACED' or 'KEPT_BOTH' - what happened to original file

  // AV1 Resource Throttling Fields (Smart CPU Management)
  warning                 String?  // User-facing warning message (e.g., "AV1 encoding will take longer")
  resourceThrottled       Boolean  @default(false) // Is job running with reduced resources?
  resourceThrottleReason  String?  // Why resources were throttled
  ffmpegThreads           Int?     // Number of threads FFmpeg is using for this job
  startedFromSeconds      Float?   // Healing point: seconds where encoding resumed from
  healingPointSeconds     Float?   // Healing point: detected resume point in temp file

  // Relations
  nodeId String
  node   Node   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  libraryId String
  library   Library @relation(fields: [libraryId], references: [id], onDelete: Cascade)

  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Restrict)

  // Relations
  history JobHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stage])
  @@index([nodeId])
  @@index([libraryId])
  @@index([policyId])
  @@index([createdAt])
  @@index([completedAt])
  @@index([updatedAt]) // LOW PRIORITY FIX #20: For watchdog queries (stuck job detection)
  @@index([stage, nodeId]) // Composite for queue queries
  @@index([isBlacklisted]) // For filtering blacklisted files
  @@index([filePath, libraryId]) // For checking if file is blacklisted during scan
  @@index([healthStatus]) // For filtering by health status
  @@index([healthScore]) // For prioritization (healthy files first)
  @@index([stage, healthScore]) // Composite for smart queue ordering
  @@index([priority]) // For priority-based queue ordering
  @@index([stage, priority, createdAt]) // Composite for efficient queue queries (ORDER BY priority DESC, createdAt ASC)
  // ISSUE #9 FIX: Unique index to prevent duplicate jobs for same file
  // Only enforces uniqueness for active jobs (not COMPLETED, FAILED, CANCELLED)
  // This prevents race conditions where multiple requests create duplicate jobs
  // NOTE: Partial unique index implemented via raw SQL migration (20251029000000_add_unique_active_job_per_file)
  // Cannot be expressed in Prisma schema syntax, handled by migration SQL directly
  @@map("jobs")
}

// ============================================================================
// JOB HISTORY MODEL (Failure/Event Tracking)
// ============================================================================

model JobHistory {
  id String @id @default(cuid())

  // Event Details
  eventType JobEventType // Type of event (FAILED, CANCELLED, etc)
  stage     JobStage // What stage the job was in when event occurred
  progress  Float // Progress percentage when event occurred

  // Error Information
  errorMessage   String? // Error message if failed
  errorDetails   String? // Additional error context
  wasAutoHealed  Boolean @default(false) // Was this a successful auto-heal?
  tempFileExists Boolean? // Did temp file exist during this event?

  // Context
  retryNumber   Int? // Which retry attempt was this?
  triggeredBy   String? // 'USER', 'SYSTEM', 'BACKEND_RESTART', 'TIMEOUT'
  systemMessage String? // User-friendly message explaining what happened

  // Performance Data (when available)
  fps              Float? // FPS at time of event
  etaSeconds       Int? // ETA at time of event
  startedFromSeconds Float? // If resumed, where it started from

  // Relations
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([eventType])
  @@index([createdAt])
  @@index([jobId, createdAt]) // For timeline queries
  @@map("job_history")
}

// ============================================================================
// METRIC MODEL (Analytics & Insights)
// ============================================================================

model Metric {
  id   String   @id @default(cuid())
  date DateTime // Date bucket for aggregation

  // Relations
  nodeId String? // Null = system-wide metric
  node   Node?   @relation(fields: [nodeId], references: [id], onDelete: Cascade)

  licenseId String? // For license-level aggregation
  license   License? @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  // Metrics
  jobsCompleted             Int    @default(0)
  jobsFailed                Int    @default(0)
  totalSavedBytes           BigInt @default(0)
  avgThroughputFilesPerHour Float  @default(0)
  codecDistribution         Json // { "H.264": 62, "HEVC": 34, "AV1": 4 }

  createdAt DateTime @default(now())

  @@unique([date, nodeId, licenseId]) // One metric per date/node/license combination
  @@index([date])
  @@index([nodeId])
  @@index([licenseId])
  @@index([date, nodeId]) // For time-series node queries
  @@map("metrics")
}
