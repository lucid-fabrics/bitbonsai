# BitBonsai Database Configuration

# ============================================================================
# SQLITE (DEFAULT - Recommended for single-node deployments)
# ============================================================================
# Zero configuration required - database file created automatically
DATABASE_URL="file:./bitbonsai.db"

# ============================================================================
# POSTGRESQL (COMMERCIAL EDITION - For multi-node deployments)
# ============================================================================
# Uncomment and update with your PostgreSQL credentials
# Remember to change datasource provider in schema.prisma to "postgresql"
# DATABASE_URL="postgresql://username:password@localhost:5432/bitbonsai?schema=public"

# ============================================================================
# CONNECTION POOLING (Optional - PostgreSQL only)
# ============================================================================
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# DATABASE_POOL_TIMEOUT=30000

# ============================================================================
# PRISMA STUDIO (Optional)
# ============================================================================
# PRISMA_STUDIO_PORT=5555
