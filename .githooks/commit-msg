#!/bin/sh
# Enforce commit message quality
MSG=$(head -1 "$1")
LEN=${#MSG}

# Block subject lines > 72 chars
if [ "$LEN" -gt 72 ]; then
  echo "ERROR: Commit subject too long ($LEN > 72 chars)" >&2
  exit 1
fi

# Block AI attribution
if echo "$MSG" | grep -qi "claude\|anthropic\|openai\|chatgpt\|copilot\|generated by\|co-authored-by.*anthropic\|co-authored-by.*openai"; then
  echo "ERROR: AI attribution detected in commit message" >&2
  exit 1
fi

exit 0
