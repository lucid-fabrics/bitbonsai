# Stage 1: Base image with common dependencies
FROM node:20-alpine AS base

# Install system dependencies (ffprobe is included with ffmpeg package)
RUN apk add --no-cache \
    ffmpeg \
    curl

# Set working directory
WORKDIR /app

# Copy package files and npm config (for Font Awesome Pro)
COPY package*.json .npmrc ./

# Install ALL dependencies (including devDependencies for development)
RUN npm install --legacy-peer-deps && \
    npm cache clean --force

# Copy Prisma schema BEFORE generating client
COPY prisma ./prisma

# Generate Prisma Client
RUN npx prisma generate

# Copy workspace configuration
COPY nx.json tsconfig.json ./

# Stage 2: Backend development image
FROM base AS backend

# Copy shared libraries
COPY libs ./libs

# Copy backend source
COPY apps/backend ./apps/backend

# Copy startup script
COPY scripts/backend-startup.sh /app/scripts/backend-startup.sh
RUN chmod +x /app/scripts/backend-startup.sh

# Expose backend ports (API + debugger)
EXPOSE 3000 9229

# Use startup script that regenerates Prisma before starting
CMD ["/app/scripts/backend-startup.sh"]

# Stage 3: Frontend development image
FROM base AS frontend

# Copy Angular configuration
COPY angular.json ./

# Copy shared libraries
COPY libs ./libs

# Copy frontend source
COPY apps/frontend ./apps/frontend

# Expose frontend port
EXPOSE 4200

# Default command
CMD ["npx", "nx", "serve", "frontend", "--host", "0.0.0.0"]

# Stage 4: Development environment (both services - for standalone use)
FROM base AS development

# Copy all workspace files
COPY . .

# Expose all ports
EXPOSE 4200 3000 9229

# Default command runs both services
CMD ["npx", "nx", "run-many", "--target=serve", "--projects=backend,frontend", "--parallel"]
