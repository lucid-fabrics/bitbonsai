FROM node:20-alpine

# Install ffmpeg and ffprobe for media analysis
RUN apk add --no-cache ffmpeg

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (including devDependencies for development)
RUN npm install --legacy-peer-deps

# Copy source code (will be overridden by volume mounts for HMR)
COPY . .

# Expose ports
EXPOSE 4200 3000

# Default command (can be overridden in docker-compose)
CMD ["npm", "run", "dev"]
