# Stage 1: Base image with common dependencies
FROM node:20-alpine AS base

# Install system dependencies
RUN apk add --no-cache \
    ffmpeg \
    ffprobe \
    curl

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install ALL dependencies (including devDependencies for development)
RUN npm install --legacy-peer-deps && \
    npm cache clean --force

# Copy workspace configuration
COPY nx.json tsconfig.json ./

# Stage 2: Backend development image
FROM base AS backend

# Copy backend source
COPY apps/backend ./apps/backend

# Expose backend ports (API + debugger)
EXPOSE 3000 9229

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

# Default command
CMD ["npx", "nx", "serve", "backend", "--host", "0.0.0.0"]

# Stage 3: Frontend development image
FROM base AS frontend

# Copy Angular configuration
COPY angular.json ./

# Copy frontend source
COPY apps/frontend ./apps/frontend

# Expose frontend port
EXPOSE 4200

# Default command
CMD ["npx", "nx", "serve", "frontend", "--host", "0.0.0.0"]

# Stage 4: Development environment (both services - for standalone use)
FROM base AS development

# Copy all workspace files
COPY . .

# Expose all ports
EXPOSE 4200 3000 9229

# Default command runs both services
CMD ["npx", "nx", "run-many", "--target=serve", "--projects=backend,frontend", "--parallel"]
