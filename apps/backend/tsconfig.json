{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "../../dist/apps/backend",
    "baseUrl": "../../",
    "incremental": true,
    "skipLibCheck": true,
    "isolatedModules": false,
    "allowJs": true,
    "paths": {
      "@bitbonsai/shared-models": ["libs/shared-models/src/index.ts"],
      "@bitbonsai/prisma-types": ["prisma/types.ts"],
      "@bitbonsai/version": ["package.json"]
    }
  },
  "exclude": ["**/*.spec.ts", "**/__tests__/**"]
}
