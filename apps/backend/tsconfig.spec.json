{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@bitbonsai/shared-models": ["libs/shared-models/src/index.ts"],
      "@bitbonsai/prisma-types": ["prisma/types.ts"],
      "@bitbonsai/version": ["apps/backend/__mocks__/@bitbonsai/version.js"]
    }
  },
  "include": [
    "src/**/*.ts",
    "**/*.spec.ts",
    "**/*.e2e.spec.ts",
    "**/*.integration.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "**/*.d.ts",
    "jest.setup.js"
  ],
  "exclude": []
}
