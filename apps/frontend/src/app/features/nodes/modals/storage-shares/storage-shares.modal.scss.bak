@use '../../../../../../styles/variables' as *;

.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.2s ease-out;
}

.modal-container {
  background: $bg-secondary;
  border-radius: 12px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  width: 90%;
  max-width: 900px;
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 1.5rem;
  border-bottom: 1px solid $border-primary;
}

.modal-header__content {
  flex: 1;
}

.modal-header__title {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 600;
  color: $text-white;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.modal-header__subtitle {
  margin: 0.5rem 0 0;
  color: $text-secondary;
  font-size: 0.9rem;
}

.modal-header__close-btn {
  background: transparent;
  border: none;
  color: $text-secondary;
  font-size: 1.5rem;
  cursor: pointer;
  padding: 0.5rem;
  border-radius: 6px;
  transition: all 0.2s;

  &:hover {
    background: $bg-tertiary;
    color: $text-white;
  }
}

.modal-body {
  padding: 1.5rem;
  overflow-y: auto;
  flex: 1;
}

.error-message {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 6px;
  padding: 0.75rem 1rem;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.error-message__icon {
  color: #ef4444;
  font-size: 1.125rem;
  flex-shrink: 0;
}

.error-message__text {
  flex: 1;
  color: var(--text-primary, #fff);
}

.error-message__close-btn {
  background: none;
  border: none;
  color: var(--text-secondary, #999);
  cursor: pointer;
  padding: 0.25rem;
  display: flex;
  align-items: center;
  justify-content: center;

  &:hover {
    color: var(--text-primary, #fff);
  }
}

.action-bar {
  display: flex;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.action-bar__button {
  padding: 0.625rem 1rem;
  border-radius: 6px;
  border: none;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.2s;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  &--primary {
    background: $accent-primary;
    color: $text-dark;

    &:hover:not(:disabled) {
      background: $accent-primary-hover;
    }
  }

  &--secondary {
    background: $bg-secondary;
    color: $text-white;
    border: 1px solid $border-primary;

    &:hover:not(:disabled) {
      background: $bg-tertiary;
      border-color: $accent-primary;
    }
  }
}

.create-form {
  background: var(--surface-elevated, #2a2a2a);
  border-radius: 8px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
}

.create-form__title {
  margin: 0 0 1.25rem;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--text-primary, #fff);
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
  margin-bottom: 1rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-group__label {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-secondary, #999);
}

.form-group__control {
  padding: 0.75rem;
  border: 1px solid var(--border-color, #333);
  border-radius: 6px;
  background: var(--surface-color, #1e1e1e);
  color: var(--text-primary, #fff);
  font-size: 0.875rem;
  transition: all 0.2s;

  &:focus {
    outline: none;
    border-color: var(--primary-color, #007bff);
    box-shadow: 0 0 0 3px rgba(0, 123, 255, 0.1);
  }

  &::placeholder {
    color: var(--text-tertiary, #666);
  }
}

.form-group--checkbox {
  flex-direction: row;
  gap: 1rem;
  align-items: center;

  .form-group__label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 400;
    cursor: pointer;
  }

  .form-group__control {
    width: auto;
    cursor: pointer;
  }
}

.smb-section {
  background: var(--surface-color, #1e1e1e);
  border: 1px solid var(--border-color, #333);
  border-radius: 6px;
  padding: 1rem;
  margin-top: 1rem;
}

.smb-section__title {
  margin: 0 0 1rem;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary, #fff);
}

.form-actions {
  margin-top: 1.5rem;
  display: flex;
  justify-content: flex-end;
}

.form-actions__button {
  padding: 0.75rem 1.5rem;
  border-radius: 6px;
  border: none;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.2s;
  background: var(--primary-color, #007bff);
  color: white;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  &:hover:not(:disabled) {
    background: var(--primary-dark, #0056b3);
  }
}

.loading-state {
  text-align: center;
  padding: 4rem 1.5rem;
  color: var(--text-secondary, #999);
}

.loading-state__icon {
  color: var(--primary-color, #007bff);
  margin-bottom: 1rem;
}

.loading-state__message {
  margin: 0;
  font-size: 1rem;
}

.empty-state {
  text-align: center;
  padding: 4rem 1.5rem;
  color: var(--text-secondary, #999);
}

.empty-state__icon {
  color: var(--text-tertiary, #666);
  margin-bottom: 1.5rem;
}

.empty-state__title {
  margin: 0 0 0.75rem;
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--text-primary, #fff);
}

.empty-state__description {
  margin: 0;
  max-width: 500px;
  margin: 0 auto;
  line-height: 1.6;
}

.shares-list {
  margin-top: 1.5rem;
}

.shares-list__title {
  margin: 0 0 1rem;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--text-primary, #fff);
}

.share-card {
  background: var(--surface-elevated, #2a2a2a);
  border: 1px solid var(--border-color, #333);
  border-radius: 8px;
  padding: 1rem;
  margin-bottom: 0.75rem;
  transition: all 0.2s;

  &:hover {
    border-color: var(--primary-color, #007bff);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  &--mounted {
    border-left: 4px solid #10b981;
  }

  &--error {
    border-left: 4px solid #ef4444;
  }

  &--testing {
    border-left: 4px solid #f59e0b;
  }

  &--available {
    border-left: 4px solid #6b7280;
  }
}

.share-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 0.75rem;
}

.share-card__info {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.share-card__icon {
  font-size: 1.25rem;
  color: var(--primary-color, #007bff);
}

.share-card__name {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.share-card__name-text {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-primary, #fff);
}

.share-card__protocol {
  font-size: 0.75rem;
  color: var(--text-secondary, #999);
  background: var(--surface-color, #1e1e1e);
  padding: 0.125rem 0.5rem;
  border-radius: 4px;
  display: inline-block;
  width: fit-content;
}

.share-card__status {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  font-weight: 500;
  padding: 0.25rem 0.75rem;
  border-radius: 6px;
  background: var(--surface-color, #1e1e1e);

  &--mounted {
    color: #10b981;
  }

  &--error {
    color: #ef4444;
  }

  &--testing {
    color: #f59e0b;
  }
}

.share-card__details {
  margin-bottom: 0.75rem;
}

.share-card__detail-row {
  display: flex;
  gap: 0.75rem;
  padding: 0.375rem 0;
  font-size: 0.875rem;

  &--error {
    .share-card__detail-value {
      color: #ef4444;
    }
  }
}

.share-card__detail-label {
  font-weight: 500;
  color: var(--text-secondary, #999);
  min-width: 100px;
}

.share-card__detail-value {
  color: var(--text-primary, #fff);
  font-family: monospace;
}

.share-card__actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.share-card__button {
  padding: 0.5rem 0.75rem;
  border-radius: 6px;
  border: none;
  font-size: 0.8125rem;
  font-weight: 500;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  transition: all 0.2s;

  &:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  &--success {
    background: #10b981;
    color: white;

    &:hover:not(:disabled) {
      background: #059669;
    }
  }

  &--warning {
    background: #f59e0b;
    color: white;

    &:hover:not(:disabled) {
      background: #d97706;
    }
  }

  &--danger {
    background: #ef4444;
    color: white;

    &:hover:not(:disabled) {
      background: #dc2626;
    }
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes slideUp {
  from {
    transform: translateY(20px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}
