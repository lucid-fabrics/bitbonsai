#=============================================================================
# BitBonsai Environment Configuration
#=============================================================================
# Copy this file to .env and update values for your environment
#
# ⚠️  SECURITY CRITICAL ⚠️
# - NEVER commit .env files to git (already in .gitignore)
# - Generate UNIQUE secrets for EACH environment
# - Use secret management in production (Azure Key Vault, AWS Secrets, etc.)
# - Rotate secrets regularly (see security policy at bottom)
#=============================================================================

#-----------------------------------------------------------------------------
# Application
#-----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

#-----------------------------------------------------------------------------
# Database Configuration
#-----------------------------------------------------------------------------
# SQLite (default for self-hosted tier)
DATABASE_URL=file:/data/bitbonsai.db

# PostgreSQL (optional - for commercial tier)
# CRITICAL: Generate strong password with: openssl rand -base64 24
# NEVER use example passwords in any environment
# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME
# POSTGRES_DB=bitbonsai
# POSTGRES_USER=<generate-unique-username>
# POSTGRES_PASSWORD=<generate-with-openssl-minimum-20-chars>

#-----------------------------------------------------------------------------
# Redis Configuration (optional - for commercial tier)
#-----------------------------------------------------------------------------
# CRITICAL: Always use authentication, even in development
# Generate password: openssl rand -base64 24
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=<generate-strong-password-minimum-20-chars>
# REDIS_TLS_ENABLED=true

#-----------------------------------------------------------------------------
# Media Configuration
#-----------------------------------------------------------------------------
# Comma-separated list of media directories to scan
MEDIA_PATHS=/media/TV,/media/Movies,/media/Anime

# Path to actual media on host (for docker volume mapping)
MEDIA_PATH=./test-media

#-----------------------------------------------------------------------------
# API Configuration
#-----------------------------------------------------------------------------
API_URL=http://localhost:3000

#-----------------------------------------------------------------------------
# Security & Authentication
#-----------------------------------------------------------------------------

## JWT Configuration (REQUIRED)
# Generate a UNIQUE secret for EACH environment:
#   openssl rand -base64 32
#
# CRITICAL SECURITY REQUIREMENTS:
#   1. NEVER use the same secret across dev/staging/production
#   2. NEVER commit the actual secret to git
#   3. Production: Store in secret management service
#      (Azure Key Vault, AWS Secrets Manager, HashiCorp Vault)
#   4. Rotate every 90 days
#
# ⚠️  GENERATE YOUR OWN SECRET - DO NOT USE ANY EXAMPLE VALUE ⚠️
JWT_SECRET=
JWT_EXPIRES_IN=24h

## Admin Credentials (TEMPORARY - Phase 1: Replace with user management)
# CRITICAL SECURITY REQUIREMENTS:
#   1. Username: Must be UNIQUE (NOT 'admin', 'root', 'administrator')
#   2. Password: MUST be STRONG:
#      - Minimum 16 characters
#      - Mix of uppercase, lowercase, numbers, special characters
#      - Generate with: openssl rand -base64 24
#   3. Production: Store in secret management (NOT in .env file)
#   4. Rotate every 30 days (until proper user management implemented)
#
# TODO Phase 1: Implement proper user management system:
#   - Database-backed users table with bcrypt password hashing
#   - Role-based access control (RBAC)
#   - Multi-factor authentication (MFA)
#   - Password reset flow
#   - Account lockout after failed attempts
#
# ⚠️  GENERATE YOUR OWN CREDENTIALS - DO NOT USE ANY EXAMPLE VALUE ⚠️
ADMIN_USERNAME=
ADMIN_PASSWORD=

## CORS Configuration
# Production frontend URL (for CORS whitelist)
# Add all authorized origins (comma-separated for multiple)
# Development: http://localhost:4200
# Production: https://your-production-domain.com
FRONTEND_URL=http://localhost:4200

#-----------------------------------------------------------------------------
# Security Headers (Recommended for production)
#-----------------------------------------------------------------------------
# Content Security Policy
# CSP_ENABLED=true
# CSP_DIRECTIVES=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# HTTP Strict Transport Security
# HSTS_ENABLED=true
# HSTS_MAX_AGE=31536000
# HSTS_INCLUDE_SUBDOMAINS=true

# Other Security Headers
# X_FRAME_OPTIONS=DENY
# X_CONTENT_TYPE_OPTIONS=nosniff
# REFERRER_POLICY=strict-origin-when-cross-origin

#-----------------------------------------------------------------------------
# Rate Limiting (Recommended to prevent abuse)
#-----------------------------------------------------------------------------
# Login endpoint protection (prevent brute force)
# RATE_LIMIT_LOGIN_MAX=5
# RATE_LIMIT_LOGIN_WINDOW_MS=900000

# Global API rate limiting
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# Per-IP rate limiting
# RATE_LIMIT_PER_IP_MAX=1000
# RATE_LIMIT_PER_IP_WINDOW_MS=3600000

#-----------------------------------------------------------------------------
# TLS/HTTPS (Required in production)
#-----------------------------------------------------------------------------
# Enable HTTPS enforcement
# FORCE_HTTPS=true

# TLS Certificate paths (if not using reverse proxy)
# TLS_CERT_PATH=/etc/ssl/certs/bitbonsai.crt
# TLS_KEY_PATH=/etc/ssl/private/bitbonsai.key

# Or use Let's Encrypt
# LETSENCRYPT_EMAIL=admin@yourdomain.com
# LETSENCRYPT_DOMAIN=bitbonsai.yourdomain.com

#-----------------------------------------------------------------------------
# Audit Logging (Recommended for security monitoring)
#-----------------------------------------------------------------------------
# AUDIT_LOG_ENABLED=true
# AUDIT_LOG_PATH=/var/log/bitbonsai/audit.log
# AUDIT_LOG_LEVEL=info
#
# Events logged:
# - Authentication attempts (success/failure)
# - Authorization failures
# - Sensitive data access
# - Configuration changes
# - User management actions

#-----------------------------------------------------------------------------
# Input Validation & Limits
#-----------------------------------------------------------------------------
# Prevent payload attacks
# MAX_REQUEST_SIZE_MB=10
# MAX_JSON_PAYLOAD_SIZE_MB=1
# MAX_FILE_UPLOAD_SIZE_MB=100

# String length limits
# MAX_USERNAME_LENGTH=50
# MAX_PASSWORD_LENGTH=128
# MAX_PATH_LENGTH=1024

#-----------------------------------------------------------------------------
# Feature Flags
#-----------------------------------------------------------------------------
# ENABLE_ANALYTICS=false
# ENABLE_METRICS=false

#-----------------------------------------------------------------------------
# Job Queue Configuration
#-----------------------------------------------------------------------------
# Threshold for detecting stuck ENCODING jobs (in minutes)
JOB_STUCK_THRESHOLD_MINUTES=5

# Maximum encoding duration before marking job as FAILED (in hours)
JOB_ENCODING_TIMEOUT_HOURS=2

#-----------------------------------------------------------------------------
# Distributed Nodes Configuration
#-----------------------------------------------------------------------------
# Node role: MAIN or LINKED
# - MAIN: Uses Prisma directly to access local SQLite database (default)
# - LINKED: Calls MAIN node's HTTP API for all data operations
NODE_ROLE=MAIN

# Main node API URL (required for LINKED nodes only)
# Example: http://192.168.1.100:3100
# This is the URL where the MAIN node's API is accessible
MAIN_API_URL=

# API Key for LINKED node authentication (auto-populated by pairing flow)
# LINKED nodes use this to authenticate with the MAIN node
# Do NOT set manually - this is automatically configured when pairing completes
API_KEY=

#-----------------------------------------------------------------------------
# License API Configuration
#-----------------------------------------------------------------------------
# License Database
LICENSE_DB_PASSWORD=  # Generate with: openssl rand -base64 24

# Encryption Key (AES-256-GCM)
ENCRYPTION_KEY=  # Generate with: openssl rand -hex 32

# Admin API Key
ADMIN_API_KEY=  # Generate with: openssl rand -hex 32

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRODUCT_ID=prod_...

# Patreon Configuration
PATREON_CLIENT_ID=
PATREON_CLIENT_SECRET=
PATREON_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=re_...

# Public URLs (for production)
LICENSE_API_URL=https://api.bitbonsai.io

#=============================================================================
# SECRET MANAGEMENT POLICY
#=============================================================================
#
# ENVIRONMENT-SPECIFIC REQUIREMENTS:
#
# Development:
#   ✓ Generate unique values (use openssl commands above)
#   ✓ Can use shorter secrets for local testing only
#   ✗ NEVER use production secrets in development
#
# Staging:
#   ✓ Use production-strength secrets (full complexity)
#   ✓ Different values from production
#   ✓ Same secret management practices as production
#
# Production (CRITICAL):
#   ✓ REQUIRED: Use secret management service
#     • Azure Key Vault
#     • AWS Secrets Manager
#     • HashiCorp Vault
#     • Google Secret Manager
#   ✗ NEVER store secrets in .env file
#   ✓ Load from secret service at runtime
#   ✓ Enable secret rotation
#   ✓ Enable access audit logging
#
# SECRET ROTATION SCHEDULE:
#   - JWT_SECRET: Every 90 days
#   - Admin password: Every 30 days (until user management implemented)
#   - Database password: Every 90 days
#   - API keys: On compromise or every 180 days
#   - Redis password: Every 90 days
#
# INCIDENT RESPONSE:
#   - Secret committed to git → ROTATE IMMEDIATELY + force push removal
#   - Secret exposed in logs → ROTATE IMMEDIATELY + audit access
#   - Suspected compromise → ROTATE IMMEDIATELY + investigate
#
# SECRET SCANNING:
#   Run these tools regularly:
#   - git-secrets (pre-commit hook)
#   - truffleHog (historical scan)
#   - detect-secrets (CI/CD pipeline)
#
# DEPLOYMENT CHECKLIST:
#   □ All secrets are unique per environment
#   □ No example/default values used
#   □ Production secrets in secret management service
#   □ .env file is in .gitignore
#   □ No secrets in git history (run: git log --all --grep='SECRET')
#   □ Rate limiting enabled
#   □ TLS/HTTPS enabled
#   □ Security headers configured
#   □ Audit logging enabled
#
#=============================================================================

# Quick Secret Generation Commands:
#
# Generate JWT secret:
#   openssl rand -base64 32
#
# Generate strong password:
#   openssl rand -base64 24
#
# Generate API key:
#   openssl rand -hex 32
#
# Test secret strength (password):
#   echo "your-password" | pwscore
#
#=============================================================================
