{
  "name": "bitbonsai-docs",
  "version": "1.0.0",
  "private": true,
  "description": "BitBonsai documentation and public repository",
  "scripts": {
    "lint": "eslint . --ext .md,.mdx && prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-markdown": "^3.0.1",
    "eslint-plugin-mdx": "^3.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "markdownlint-cli": "^0.39.0",
    "prettier": "^3.2.0"
  },
  "lint-staged": {
    "*.{md,mdx}": [
      "prettier --write",
      "markdownlint --fix",
      "eslint --ext .md,.mdx"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
