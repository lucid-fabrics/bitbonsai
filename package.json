{
  "name": "media-insight",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:api": "cd apps/backend && nest start --watch",
    "build": "ng build",
    "build:api": "cd apps/backend && nest build",
    "build:all": "npm run build && npm run build:api",
    "docker:build": "docker build -f Dockerfile -t lucidfabrics/media-insight:latest -t lucidfabrics/media-insight:$npm_package_version .",
    "docker:push": "docker push lucidfabrics/media-insight:latest && docker push lucidfabrics/media-insight:$npm_package_version",
    "docker:build-push": "npm run docker:build && npm run docker:push",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags",
    "test": "ng test",
    "test:api": "cd apps/backend && jest",
    "lint": "ng lint"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/compiler": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/forms": "^19.0.0",
    "@angular/platform-browser": "^19.0.0",
    "@angular/platform-browser-dynamic": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@ngrx/effects": "^19.0.0",
    "@ngrx/store": "^19.0.0",
    "@ngrx/store-devtools": "^19.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.0.0",
    "@angular/cli": "^19.0.0",
    "@angular/compiler-cli": "^19.0.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@ngrx/schematics": "^19.0.0",
    "@nx/angular": "^21.5.3",
    "@nx/eslint": "^21.5.3",
    "@nx/jest": "^21.5.3",
    "@nx/js": "^21.5.3",
    "@nx/webpack": "^21.6.2",
    "@nx/workspace": "^21.5.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "nx": "^21.5.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "~5.5.0"
  }
}
